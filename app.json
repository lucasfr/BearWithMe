{
  "expo": {
    "name": "Bear with Me",
    "slug": "bear-with-me",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#F5EFE6"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.circadia.bearwithme",
      "icon": "./assets/images/icon.png"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#F5EFE6"
      },
      "package": "com.circadia.bearwithme"
    },
    "scheme": "bear-with-me",
    "plugins": [
      "expo-router",
      "@react-native-community/datetimepicker"
    ],
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/icons/favicon.ico",
      "name": "Bear with Me",
      "shortName": "Bear with Me",
      "description": "A quiet promise tracker for people who care deeply and sometimes struggle to follow through.",
      "themeColor": "#6F4E37",
      "backgroundColor": "#F5EFE6",
      "display": "standalone",
      "orientation": "portrait"
    }
  }
}
