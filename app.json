{
  "expo": {
    "name": "Bear with Me",
    "slug": "bear-with-me",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#F5EFE6"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.circadia.bearwithme",
      "icon": "./assets/images/icon.png"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#F5EFE6"
      },
      "package": "com.circadia.bearwithme"
    },
    "scheme": "bear-with-me",
    "plugins": ["expo-router"],
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/icons/favicon.ico"
    }
  }
}
